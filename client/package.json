{
  "name": "edra-client",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "prepare:media": "node scripts/sync-media.mjs",
    "predev": "npm run prepare:media && npm run generate:importmap",
    "prebuild": "npm run prepare:media && npm run generate:importmap",
    "prestart": "npm run prepare:media && npm run generate:importmap && node scripts/copy-standalone.mjs",
    "dev": "next dev --turbopack",
    "build": "next build",
    "postbuild": "node scripts/copy-standalone.mjs",
    "start": "node scripts/start-prod.mjs",
    "media:audit-orphans": "node --experimental-strip-types scripts/prune-orphan-media-docs.ts",
    "media:prune-orphans": "node --experimental-strip-types scripts/prune-orphan-media-docs.ts --apply",
    "db:migrate-old-to-new": "node --experimental-strip-types scripts/migrate-old-db-to-new-db.mjs",
    "db:copy-cms-old-to-new": "node --experimental-strip-types scripts/copy-cms-data-between-dbs.mjs",
    "media:migrate-blob": "node --experimental-strip-types scripts/migrate-media-to-blob-sql.mjs",
    "media:migrate-blob:apply": "node --experimental-strip-types scripts/migrate-media-to-blob-sql.mjs --apply",
    "generate:importmap": "node --experimental-strip-types node_modules/payload/dist/bin/index.js generate:importmap && node scripts/ensure-importmap-blob.mjs",
    "seed": "node --experimental-strip-types seed.ts"
  },
  "dependencies": {
    "@base-ui/react": "^1.2.0",
    "@payloadcms/db-postgres": "3.79.0",
    "@payloadcms/next": "3.79.0",
    "@payloadcms/richtext-lexical": "3.79.0",
    "@payloadcms/storage-vercel-blob": "^3.79.0",
    "@swc/helpers": "^0.5.19",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^17.3.1",
    "framer-motion": "^12.34.3",
    "graphql": "16.13.1",
    "gsap": "^3.12.5",
    "lenis": "^1.3.19",
    "lucide-react": "^0.577.0",
    "motion": "^12.38.0",
    "next": "15.4.11",
    "payload": "3.79.0",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "shadcn": "^4.0.2",
    "sharp": "0.34.5",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "autoprefixer": "^10.4.27",
    "postcss": "^8.5.8",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.21.0",
    "typescript": "5.9.3"
    "@vercel/analytics": "^1.6.1",
    "@vercel/og": "^0.6.0",
    "@vercel/speed-insights": "^1.3.1"
  }
}
